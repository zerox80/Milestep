# KoWoBau-Planner environment example
#
# Copy to .env for local Docker Compose usage:
#   Copy-Item .env.example .env
#
# Keep .env private. Generate a strong secret (at least 32 characters):
#   PowerShell: [Convert]::ToBase64String((1..48 | ForEach-Object { Get-Random -Maximum 256 }))
#   Linux/macOS: openssl rand -base64 48

# Docker Compose localhost-only published ports.
# Defaults map Docker Nginx to http://127.0.0.1 and Postgres to 127.0.0.1:5432.
KOWOBAU_HTTP_PORT=80
KOWOBAU_POSTGRES_PORT=5432

# Backend database connection.
# Inside Docker Compose this is derived from POSTGRES_PASSWORD automatically;
# only set it explicitly for non-Compose setups.
# DATABASE_URL=postgres://kowobau:<password>@postgres:5432/kowobau

# Axum backend bind address inside the app container.
KOWOBAU_BIND=0.0.0.0:8080

# Files uploaded through the app are stored here inside the app container.
KOWOBAU_UPLOAD_DIR=/app/uploads

# Only needed when running the backend without the Docker Nginx frontend.
# KOWOBAU_STATIC_DIR=/app/public

# Required: the backend refuses to start without it (minimum 32 characters).
# Generate a fresh value, see top of this file.
KOWOBAU_SESSION_SECRET=

# Local HTTP defaults to false. Set true behind HTTPS in production
# (the session cookie then also gets the __Host- prefix).
KOWOBAU_COOKIE_SECURE=false

# Optional but recommended in production: the exact public origin of the app,
# e.g. https://kowobau.example.com - state-changing browser requests must then
# carry exactly this Origin header (CSRF hardening incl. scheme).
KOWOBAU_PUBLIC_ORIGIN=

# Set true only when a reverse proxy in front of the backend sets X-Real-IP
# (the bundled Docker nginx does). Used for auth rate limiting.
# Compose sets this automatically; only relevant for non-Compose setups.
# KOWOBAU_TRUST_PROXY=true

# Seed the demo workspace (7 accounts, password "password123") on an EMPTY
# database. Leave false in production; set true to try the demo locally.
KOWOBAU_SEED_DEMO=false

# Optional: total attachment storage per workspace in bytes (default 2 GiB).
# KOWOBAU_MAX_WORKSPACE_STORAGE_BYTES=2147483648

# Postgres container settings used by docker-compose.yml.
# POSTGRES_PASSWORD is required: Compose refuses to start without it.
# Generate a strong value, see top of this file.
POSTGRES_USER=kowobau
POSTGRES_PASSWORD=
POSTGRES_DB=kowobau
