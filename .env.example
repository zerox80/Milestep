# KoWoBau-Planner environment example
#
# Copy to .env for local Docker Compose usage:
#   Copy-Item .env.example .env
#
# Keep .env private. Generate a strong production secret:
#   openssl rand -hex 32

# Docker Compose localhost-only published ports.
# Defaults map Docker Nginx to http://127.0.0.1 and Postgres to 127.0.0.1:5432.
KOWOBAU_HTTP_PORT=80
KOWOBAU_POSTGRES_PORT=5432

# Backend database connection.
# Inside Docker Compose, keep the postgres hostname.
DATABASE_URL=postgres://kowobau:kowobau@postgres:5432/kowobau

# Axum backend bind address inside the app container.
KOWOBAU_BIND=0.0.0.0:8080

# Files uploaded through the app are stored here inside the app container.
KOWOBAU_UPLOAD_DIR=/app/uploads

# Only needed when running the backend without the Docker Nginx frontend.
# KOWOBAU_STATIC_DIR=/app/public

# Replace this before any real deployment.
KOWOBAU_SESSION_SECRET=change-me-generate-with-openssl-rand-hex-32

# Local HTTP defaults to false. Set true behind HTTPS in production.
KOWOBAU_COOKIE_SECURE=false

# Postgres container settings used by docker-compose.yml.
POSTGRES_USER=kowobau
POSTGRES_PASSWORD=kowobau
POSTGRES_DB=kowobau
